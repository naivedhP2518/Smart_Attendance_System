# ------------------------------------------------------------------------------
# Full-Stack Monorepo Gitignore
# Covers: React (Frontend), Node.js (Backend), Python (Agents), OS Files
# ------------------------------------------------------------------------------

# ==================================
# 1. Node.js & Dependencies
# ==================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ==================================
# 2. Environment Variables & Secrets
# ==================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ==================================
# 3. Python & Virtual Environments
# ==================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
env.bak/
venv.bak/

# ==================================
# 4. Frontend & Backend Builds
# ==================================
build/
dist/
/frontend/build/
/frontend/dist/
.next/
out/

# ==================================
# 5. Testing & Coverage
# ==================================
coverage/
.nyc_output/

# ==================================
# 6. Database & Uploads
# ==================================
*.sqlite3
*.db
# Ignore the contents of the attendance_records folder (local uploads) but keep the folder
backend/attendance_records/*
!backend/attendance_records/.gitkeep

# ==================================
# 7. OS & Editor Files
# ==================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
